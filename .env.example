# Copy to .env and fill in
#
# LLM API keys — set whichever providers you want to use. Models are routed
# through LiteLLM based on the model-name prefix (see CV_SCREENER_MODEL_*
# below). LiteLLM auto-picks the key for the matching provider.
TOGETHER_API_KEY=your_together_api_key_here
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Web UI login (required if running `cv-screener serve`)
CV_SCREENER_USERNAME=admin
CV_SCREENER_PASSWORD=changeme

# Brave Search API key — used by specialist agents to ground their judgements
# with web evidence (companies, technologies, institutions). If unset, agents
# proceed without web search.
BRAVE_API_KEY=

# Optional: persistent session-cookie signing key. If unset, a random key is
# generated per process start (sessions don't survive a server restart).
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# CV_SCREENER_SECRET_KEY=

# Optional: override default model per role. Use LiteLLM-style prefixes:
#   together_ai/openai/gpt-oss-20b
#   together_ai/meta-llama/Llama-3.3-70B-Instruct-Turbo
#   openai/gpt-4o          (needs OPENAI_API_KEY)
#   anthropic/claude-sonnet-4-6  (needs ANTHROPIC_API_KEY)
#   gemini/gemini-2.0-flash      (needs GEMINI_API_KEY)
# Defaults: parser/aggregator on gpt-oss-20b, specialists on Llama-3.3-70B.
# CV_SCREENER_MODEL_PARSER=together_ai/openai/gpt-oss-20b
# CV_SCREENER_MODEL_SPECIALIST=together_ai/meta-llama/Llama-3.3-70B-Instruct-Turbo
# CV_SCREENER_MODEL_AGGREGATOR=together_ai/openai/gpt-oss-20b
# CV_SCREENER_MODEL_CHAT=together_ai/openai/gpt-oss-20b
