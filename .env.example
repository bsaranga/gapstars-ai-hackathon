# Copy to .env and fill in
TOGETHER_API_KEY=your_together_api_key_here

# Web UI login (required if running `cv-screener serve`)
CV_SCREENER_USERNAME=admin
CV_SCREENER_PASSWORD=changeme

# Optional: persistent session-cookie signing key. If unset, a random key is
# generated per process start (sessions don't survive a server restart).
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# CV_SCREENER_SECRET_KEY=

# Optional: override default model for any role
# CV_SCREENER_MODEL_PARSER=openai/gpt-oss-20b
# CV_SCREENER_MODEL_SPECIALIST=openai/gpt-oss-20b
# CV_SCREENER_MODEL_AGGREGATOR=openai/gpt-oss-20b
